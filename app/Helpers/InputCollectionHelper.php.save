            case 'SD-SURABAYA':
                $inputs = collect([
                    'payment_form' => [
                        'nama' => 'Bukti Bayar Formulir',
                        'validation' => 'required'
                    ],
                    'birth_certificate' => [
                        'nama' => 'Akta Kelahiran',
                        'validation' => 'required',
                    ],
                    'photo' => [
